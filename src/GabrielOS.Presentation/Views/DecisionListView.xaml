<UserControl x:Class="GabrielOS.Presentation.Views.DecisionListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GabrielOS.Presentation.Converters">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveDecisionCommand}"/>
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Decision Log" Style="{StaticResource H1}" Margin="0,0,0,16"/>

        <!-- Form -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="{Binding FormTitle}" Style="{StaticResource H3}" Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}" Margin="0,0,6,0"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding StatusValues}" SelectedItem="{Binding NewStatus}"
                              Style="{StaticResource DarkComboBox}" Margin="0,0,6,0"/>
                    <ComboBox Grid.Column="2" ItemsSource="{Binding Pillars}" SelectedItem="{Binding NewPillar}"
                              DisplayMemberPath="Name" Style="{StaticResource DarkComboBox}"/>
                </Grid>

                <TextBox Text="{Binding NewContext, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkTextBox}"
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                         Margin="0,0,0,8"/>

                <TextBox Text="{Binding NewChosenOption, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkTextBox}"
                         Margin="0,0,0,8"/>

                <TextBox Text="{Binding NewRationale, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkTextBox}"
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48"
                         Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="{Binding SaveButtonText}" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveDecisionCommand}" Margin="0,0,8,0"/>
                    <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                            Command="{Binding CancelEditCommand}"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Search + List -->
        <DockPanel Grid.Row="2" Margin="0,4,0,0">
            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkTextBox}" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="Search" Style="{StaticResource PrimaryButton}"
                        Command="{Binding SearchCommand}"/>
            </Grid>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                <ItemsControl ItemsSource="{Binding Decisions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Status}" Style="{StaticResource SecondaryText}"
                                                       Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Text=" · " Style="{StaticResource SecondaryText}"/>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd MMM yyyy}'}"
                                                       Style="{StaticResource SecondaryText}"/>
                                            <TextBlock Text=" · " Style="{StaticResource SecondaryText}"
                                                       Visibility="{Binding Pillar, Converter={StaticResource NullToVisibilityConverter}}"/>
                                            <TextBlock Text="{Binding Pillar.Name}" Style="{StaticResource SecondaryText}"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       Visibility="{Binding Pillar, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="Edit" Style="{StaticResource SecondaryButton}"
                                                    Command="{Binding DataContext.BeginEditDecisionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" Margin="0,0,6,0"/>
                                            <Button Content="Delete" Style="{StaticResource DangerButton}"
                                                    Command="{Binding DataContext.DeleteDecisionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="{Binding Title}" Style="{StaticResource BodyText}"
                                               FontWeight="SemiBold" Margin="0,4,0,2"/>
                                    <TextBlock Text="{Binding Context}" Style="{StaticResource SecondaryText}"
                                               TextWrapping="Wrap" MaxHeight="60" TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,2"/>
                                    <TextBlock Style="{StaticResource SecondaryText}" TextWrapping="Wrap" Margin="0,2,0,0"
                                               Visibility="{Binding ChosenOption, Converter={StaticResource NullToVisibilityConverter}}">
                                        <Run Text="Decision: " FontWeight="SemiBold"/>
                                        <Run Text="{Binding ChosenOption}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                    <StackPanel Style="{StaticResource EmptyState}"
                                Visibility="{Binding Decisions.Count, Converter={StaticResource InverseToVisibilityConverter}}">
                        <TextBlock Text="△" FontSize="32" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="No decisions logged" Style="{StaticResource H3}"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="Log a decision above to start your decision journal." Style="{StaticResource SecondaryText}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
