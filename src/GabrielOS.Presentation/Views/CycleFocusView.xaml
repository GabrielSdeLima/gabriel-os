<UserControl x:Class="GabrielOS.Presentation.Views.CycleFocusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GabrielOS.Presentation.Converters">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding CreateCycleCommand}"/>
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Cycle Focus" Style="{StaticResource H1}" Margin="0,0,0,16"/>

        <!-- Active cycle -->
        <Border Grid.Row="1" Style="{StaticResource Card}"
                Visibility="{Binding ActiveCycleFocus, Converter={StaticResource NullToVisibilityConverter}}">
            <StackPanel>
                <Grid>
                    <TextBlock Text="Active Cycle" Style="{StaticResource H3}"
                               Foreground="{StaticResource AccentBrush}"/>
                    <Button Content="Complete Cycle" Style="{StaticResource SecondaryButton}"
                            Command="{Binding DeactivateCycleCommand}"
                            HorizontalAlignment="Right"/>
                </Grid>
                <TextBlock Text="{Binding ActiveCycleFocus.Title}" Style="{StaticResource BodyText}"
                           FontWeight="SemiBold" Margin="0,8,0,2"/>
                <TextBlock Text="{Binding ActiveCycleFocus.Thesis}" Style="{StaticResource SecondaryText}"
                           TextWrapping="Wrap" Margin="0,0,0,8"
                           Visibility="{Binding ActiveCycleFocus.Thesis, Converter={StaticResource NullToVisibilityConverter}}"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{StaticResource SecondaryText}">
                        <Run Text="{Binding ActiveCycleFocus.StartDate, StringFormat='{}{0:dd MMM yyyy}'}"/>
                        <Run Text=" → "/>
                        <Run Text="{Binding ActiveCycleFocus.EndDate, StringFormat='{}{0:dd MMM yyyy}'}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Linked goals -->
                <ItemsControl ItemsSource="{Binding ActiveCycleFocus.CycleFocusGoals}" Margin="0,8,0,0"
                              Visibility="{Binding ActiveCycleFocus.CycleFocusGoals.Count, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource SecondaryText}" Margin="0,2,0,0">
                                <Run Text="→ "/>
                                <Run Text="{Binding Goal.Title}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- New cycle form -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="New Cycle" Style="{StaticResource H3}" Margin="0,0,0,8"/>

                <TextBox Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkTextBox}" Margin="0,0,0,8"/>

                <TextBox Text="{Binding NewThesis, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkTextBox}"
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48"
                         Margin="0,0,0,8"/>

                <TextBlock Text="Duration" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <DatePicker Grid.Column="0" SelectedDate="{Binding NewStartDate}"
                                Style="{StaticResource DarkDatePicker}" Width="140"/>
                    <TextBlock Grid.Column="1" Text="  →  " Style="{StaticResource SecondaryText}"
                               VerticalAlignment="Center"/>
                    <DatePicker Grid.Column="2" SelectedDate="{Binding NewEndDate}"
                                Style="{StaticResource DarkDatePicker}" Width="140"/>
                </Grid>

                <Button Content="Activate Cycle" Style="{StaticResource PrimaryButton}"
                        Command="{Binding CreateCycleCommand}" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <!-- Past cycles -->
        <DockPanel Grid.Row="3" Margin="0,4,0,0">
            <TextBlock DockPanel.Dock="Top" Text="Past Cycles" Style="{StaticResource H3}" Margin="0,0,0,8"/>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding PastCycles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" Style="{StaticResource BodyText}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Style="{StaticResource SecondaryText}" Margin="0,4,0,0">
                                            <Run Text="{Binding StartDate, StringFormat='{}{0:dd MMM yyyy}'}"/>
                                            <Run Text=" → "/>
                                            <Run Text="{Binding EndDate, StringFormat='{}{0:dd MMM yyyy}'}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Content="Delete" Style="{StaticResource DangerButton}"
                                            Command="{Binding DataContext.DeleteCycleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
