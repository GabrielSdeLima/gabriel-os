<UserControl x:Class="GabrielOS.Presentation.Views.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GabrielOS.Presentation.Converters"
             xmlns:vm="clr-namespace:GabrielOS.Presentation.ViewModels"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:InverseToVisibilityConverter x:Key="InverseToVisibilityConverter"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:CalendarItemSourceColorConverter x:Key="SourceColorConverter"/>
        <conv:CalendarItemSourceLabelConverter x:Key="SourceLabelConverter"/>
        <conv:LegendColorKeyConverter x:Key="LegendColorKeyConverter"/>

        <!-- Day cell button style -->
        <Style x:Key="DayCellButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Margin="2" Padding="4,3"
                                MinHeight="62" MinWidth="50"
                                BorderThickness="1" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BackgroundTertiaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Event item in sidebar -->
        <Style x:Key="EventItemBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundTertiaryBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Calendário" Style="{StaticResource H1}"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Style="{StaticResource SecondaryText}">
                        <Run Text="{Binding MonthEventCount}"/>
                        <Run Text="eventos este mês"/>
                    </TextBlock>
                    <TextBlock Text=" · " Style="{StaticResource SecondaryText}"/>
                    <TextBlock Style="{StaticResource SecondaryText}">
                        <Run Text="{Binding UpcomingCount}"/>
                        <Run Text="nos próximos 7 dias"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
            <Button Grid.Column="1" Content="Hoje"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding GoToTodayCommand}"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- Main content: Calendar + Sidebar -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="480"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- ══ LEFT: Calendar Grid ══ -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                <DockPanel>
                    <!-- Month navigation -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button Style="{StaticResource GhostButton}" Command="{Binding PreviousMonthCommand}"
                                    Padding="8,4" Margin="0,0,12,0">
                                <iconPacks:PackIconLucide Kind="ChevronLeft" Width="16" Height="16"
                                                          Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Button>
                            <TextBlock Text="{Binding MonthYearDisplay}"
                                       Style="{StaticResource H2}" MinWidth="180" TextAlignment="Center"/>
                            <Button Style="{StaticResource GhostButton}" Command="{Binding NextMonthCommand}"
                                    Padding="8,4" Margin="12,0,0,0">
                                <iconPacks:PackIconLucide Kind="ChevronRight" Width="16" Height="16"
                                                          Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Day-of-week headers -->
                    <UniformGrid DockPanel.Dock="Top" Rows="1" Columns="7" Margin="0,0,0,4">
                        <TextBlock Text="Seg" Style="{StaticResource SecondaryText}" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="Ter" Style="{StaticResource SecondaryText}" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="Qua" Style="{StaticResource SecondaryText}" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="Qui" Style="{StaticResource SecondaryText}" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="Sex" Style="{StaticResource SecondaryText}" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="Sáb" Style="{StaticResource SecondaryText}" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="Dom" Style="{StaticResource SecondaryText}" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    </UniformGrid>

                    <!-- Calendar grid (6 rows × 7 columns = 42 cells) -->
                    <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding Days}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="6" Columns="7"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:CalendarDayViewModel}">
                                <Button Command="{Binding DataContext.SelectDayCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource DayCellButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource AccentSubtleBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Day number -->
                                        <Grid Grid.Row="0" HorizontalAlignment="Right">
                                            <Border CornerRadius="12" Padding="5,2" Margin="-2,-1"
                                                    Background="Transparent">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource AccentPrimaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding DayNumber}" FontSize="13" FontWeight="Medium"
                                                           HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextInverseBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </Grid>

                                        <!-- Energy heatmap strip -->
                                        <Border Grid.Row="1" CornerRadius="2" Height="3" Margin="4,4,4,2"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding HasCheckIn, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource SemanticInfoBrush}"/>
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        <!-- Event dots -->
                                        <ItemsControl Grid.Row="2" ItemsSource="{Binding EventDots}"
                                                      HorizontalAlignment="Center" Margin="0,2,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Ellipse Width="5" Height="5" Margin="1.5,0"
                                                             Fill="{Binding Converter={StaticResource SourceColorConverter}}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <!-- ══ RIGHT: Selected Day + Event Form ══ -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Selected date header -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedDateDisplay}" Style="{StaticResource H3}" Margin="0,0,0,8"/>

                            <!-- Events for selected date -->
                            <ItemsControl ItemsSource="{Binding SelectedDateItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource EventItemBorder}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Color bar -->
                                                <Border Grid.Column="0" CornerRadius="2" Width="4" Margin="0,0,10,0"
                                                        Background="{Binding Converter={StaticResource SourceColorConverter}}"/>

                                                <!-- Event details -->
                                                <StackPanel Grid.Column="1">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                        <TextBlock Text="{Binding Source, Converter={StaticResource SourceLabelConverter}}"
                                                                   Style="{StaticResource SecondaryText}" FontWeight="SemiBold"
                                                                   FontSize="11"/>
                                                        <TextBlock Text=" · " Style="{StaticResource SecondaryText}" FontSize="11"
                                                                   Visibility="{Binding EventType, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                        <TextBlock Text="{Binding EventType}"
                                                                   Style="{StaticResource SecondaryText}" FontSize="11"
                                                                   Visibility="{Binding EventType, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                        <TextBlock Style="{StaticResource SecondaryText}" FontSize="11" Margin="6,0,0,0"
                                                                   Visibility="{Binding StartTime, Converter={StaticResource NullToVisibilityConverter}}">
                                                            <Run Text="{Binding StartTime, StringFormat=hh\\:mm}"/>
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <TextBlock FontSize="14" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               TextWrapping="Wrap">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="{Binding Title}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                        <Setter Property="Opacity" Value="0.5"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <TextBlock Text="{Binding Description}" Style="{StaticResource SecondaryText}"
                                                               TextWrapping="Wrap" MaxHeight="40" TextTrimming="CharacterEllipsis"
                                                               Visibility="{Binding Description, Converter={StaticResource NullToVisibilityConverter}}"
                                                               Margin="0,2,0,0"/>

                                                    <TextBlock Style="{StaticResource SecondaryText}" FontSize="11" Margin="0,2,0,0"
                                                               Visibility="{Binding Location, Converter={StaticResource NullToVisibilityConverter}}">
                                                        <Run Text="Local:"/>
                                                        <Run Text="{Binding Location}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Action buttons for user events -->
                                                <StackPanel Grid.Column="2" VerticalAlignment="Top">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Source}" Value="UserEvent">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <Button Style="{StaticResource GhostButton}" Padding="4,2"
                                                            Command="{Binding DataContext.ToggleCompleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" ToolTip="Concluir">
                                                        <iconPacks:PackIconLucide Kind="Check" Width="13" Height="13"
                                                                                  Foreground="{DynamicResource SemanticSuccessBrush}"/>
                                                    </Button>
                                                    <Button Style="{StaticResource GhostButton}" Padding="4,2"
                                                            Command="{Binding DataContext.BeginEditEventCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" ToolTip="Editar">
                                                        <iconPacks:PackIconLucide Kind="Pencil" Width="13" Height="13"
                                                                                  Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    </Button>
                                                    <Button Style="{StaticResource GhostButton}" Padding="4,2"
                                                            Command="{Binding DataContext.DeleteEventCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" ToolTip="Excluir">
                                                        <iconPacks:PackIconLucide Kind="Trash2" Width="13" Height="13"
                                                                                  Foreground="{DynamicResource SemanticErrorBrush}"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Empty state for selected date -->
                            <TextBlock Text="Nenhum evento neste dia"
                                       HorizontalAlignment="Center" Margin="0,12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryText}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedDateItems.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Add event button -->
                            <Button Style="{StaticResource PrimaryButton}" Margin="0,8,0,0"
                                    Command="{Binding ShowNewEventFormCommand}"
                                    HorizontalAlignment="Stretch"
                                    Visibility="{Binding ShowEventForm, Converter={StaticResource InverseToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <iconPacks:PackIconLucide Kind="Plus" Width="14" Height="14"
                                                              VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Novo Evento"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- ══ EVENT FORM ══ -->
                    <Border Style="{StaticResource Card}"
                            Visibility="{Binding ShowEventForm, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{Binding FormTitle}" Style="{StaticResource H3}" Margin="0,0,0,10"/>

                            <!-- Title -->
                            <TextBlock Text="Título" Style="{StaticResource SecondaryText}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DarkTextBox}" Margin="0,0,0,10"/>

                            <!-- Type + Priority row -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                    <TextBlock Text="Tipo" Style="{StaticResource SecondaryText}" FontSize="11" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding EventTypeValues}"
                                              Text="{Binding NewEventType, UpdateSourceTrigger=LostFocus}"
                                              IsEditable="True"
                                              Style="{StaticResource DarkComboBox}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                    <TextBlock Text="Prioridade" Style="{StaticResource SecondaryText}" FontSize="11" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding PriorityValues}" SelectedItem="{Binding NewPriority}"
                                              Style="{StaticResource DarkComboBox}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Date -->
                            <TextBlock Text="Data" Style="{StaticResource SecondaryText}" FontSize="11" Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding NewDate}" Style="{StaticResource DarkDatePicker}"
                                        Margin="0,0,0,10"/>

                            <!-- All day toggle -->
                            <CheckBox Content="Dia inteiro" Style="{StaticResource DarkCheckBox}"
                                      IsChecked="{Binding NewIsAllDay}" Margin="0,0,0,10"/>

                            <!-- Time fields (visible when not all-day) -->
                            <Grid Margin="0,0,0,10"
                                  Visibility="{Binding NewIsAllDay, Converter={StaticResource InverseToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                    <TextBlock Text="Início (hh:mm)" Style="{StaticResource SecondaryText}" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding NewStartTime, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource DarkTextBox}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                    <TextBlock Text="Fim (hh:mm)" Style="{StaticResource SecondaryText}" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding NewEndTime, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource DarkTextBox}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Location -->
                            <TextBlock Text="Local" Style="{StaticResource SecondaryText}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewLocation, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DarkTextBox}" Margin="0,0,0,10"/>

                            <!-- Description -->
                            <TextBlock Text="Descrição" Style="{StaticResource SecondaryText}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DarkTextBox}" AcceptsReturn="True"
                                     TextWrapping="Wrap" MinHeight="60" MaxHeight="100"
                                     VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>

                            <!-- Goal link -->
                            <TextBlock Text="Vincular a meta" Style="{StaticResource SecondaryText}" FontSize="11" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Goals}" SelectedItem="{Binding NewGoal}"
                                      DisplayMemberPath="Title" Style="{StaticResource DarkComboBox}"
                                      Margin="0,0,0,10"/>

                            <!-- Pillar link -->
                            <TextBlock Text="Vincular a pilar" Style="{StaticResource SecondaryText}" FontSize="11" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Pillars}" SelectedItem="{Binding NewPillar}"
                                      DisplayMemberPath="Name" Style="{StaticResource DarkComboBox}"
                                      Margin="0,0,0,12"/>

                            <!-- Buttons -->
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{Binding SaveButtonText}" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding SaveEventCommand}" Margin="0,0,8,0"/>
                                <Button Content="Cancelar" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding CancelEventFormCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ══ LEGEND (dynamic — only shows types present this month) ══ -->
                    <Border Style="{StaticResource Card}"
                            Visibility="{Binding LegendEntries.Count, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Legenda" Style="{StaticResource H3}" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding LegendEntries}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,14,6">
                                            <Ellipse Width="8" Height="8" Margin="0,0,5,0"
                                                     Fill="{Binding ColorKey, Converter={StaticResource LegendColorKeyConverter}}"/>
                                            <TextBlock Text="{Binding Label}" Style="{StaticResource SecondaryText}" FontSize="11"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
