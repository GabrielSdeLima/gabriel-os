<UserControl x:Class="GabrielOS.Presentation.Views.JournalListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GabrielOS.Presentation.Converters">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Journal" Style="{StaticResource H1}" Margin="0,0,0,16"/>

        <!-- Entry Form (create & edit) -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="{Binding FormTitle}" Style="{StaticResource H3}" Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}"
                             Margin="0,0,8,0"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding EntryTypes}"
                              SelectedItem="{Binding NewEntryType}"
                              Style="{StaticResource DarkComboBox}"/>
                </Grid>

                <TextBox Text="{Binding NewContent, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkTextBox}"
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"
                         Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0"
                              IsChecked="{Binding NewIsSensitive}"
                              Content="Sensitive entry"
                              Style="{StaticResource DarkCheckBox}"
                              VerticalAlignment="Center"/>
                </Grid>

                <StackPanel Orientation="Horizontal">
                    <Button Content="{Binding SaveButtonText}"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveEntryCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="Cancel"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding CancelEditCommand}"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Search + Entries List -->
        <DockPanel Grid.Row="2" Margin="0,16,0,0">
            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkTextBox}"
                         Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="Search"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SearchCommand}"/>
            </Grid>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Entries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <!-- Header row -->
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding EntryType}"
                                                       Style="{StaticResource SecondaryText}"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text=" · " Style="{StaticResource SecondaryText}"/>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd MMM yyyy HH:mm}'}"
                                                       Style="{StaticResource SecondaryText}"/>
                                            <TextBlock Text=" · 🔒" Style="{StaticResource SecondaryText}"
                                                       Foreground="{StaticResource WarningBrush}"
                                                       Visibility="{Binding IsSensitive, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>

                                        <!-- Actions -->
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="Edit"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Command="{Binding DataContext.BeginEditEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,0,6,0"/>
                                            <Button Content="Delete"
                                                    Style="{StaticResource DangerButton}"
                                                    Command="{Binding DataContext.DeleteEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="{Binding Title}"
                                               Style="{StaticResource BodyText}"
                                               FontWeight="SemiBold"
                                               Margin="0,4,0,2"
                                               Visibility="{Binding Title, Converter={StaticResource NullToVisibilityConverter}}"/>

                                    <TextBlock Text="{Binding Content}"
                                               Style="{StaticResource BodyText}"
                                               TextWrapping="Wrap"
                                               MaxHeight="100"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
