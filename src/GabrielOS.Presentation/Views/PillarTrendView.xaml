<UserControl x:Class="GabrielOS.Presentation.Views.PillarTrendView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Pillar Trends" Style="{StaticResource H1}" Margin="0,0,0,16"/>

        <!-- Controls -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Show:" Style="{StaticResource SecondaryText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox ItemsSource="{Binding WeekOptions}" SelectedItem="{Binding WeeksToShow}"
                      Style="{StaticResource DarkComboBox}" Width="80" Margin="0,0,8,0"/>
            <TextBlock Text="weeks" Style="{StaticResource SecondaryText}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Chart -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <oxy:PlotView Model="{Binding PillarTrendModel}" MinHeight="350"
                          Background="Transparent"/>
        </Border>
    </Grid>
</UserControl>
