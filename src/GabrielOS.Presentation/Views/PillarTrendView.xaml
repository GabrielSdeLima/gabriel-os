<UserControl x:Class="GabrielOS.Presentation.Views.PillarTrendView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Pillar Trends" Style="{StaticResource H1}" Margin="0,0,0,16"/>

        <!-- Controls -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Show:" Style="{StaticResource SecondaryText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox ItemsSource="{Binding WeekOptions}" SelectedItem="{Binding WeeksToShow}"
                      Style="{StaticResource DarkComboBox}" Width="80" Margin="0,0,8,0"/>
            <TextBlock Text="weeks" Style="{StaticResource SecondaryText}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Chart or empty state -->
        <Grid Grid.Row="2">
            <Border Style="{StaticResource Card}" Padding="0"
                    Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}">
                <oxy:PlotView Model="{Binding PillarTrendModel}" MinHeight="350"
                              Background="Transparent"/>
            </Border>
            <StackPanel Style="{StaticResource EmptyState}"
                        Visibility="{Binding HasData, Converter={StaticResource InverseToVisibilityConverter}}">
                <TextBlock Text="📈" FontSize="32" Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="No data yet" Style="{StaticResource H3}"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Log check-ins and pillar scores to see your trends here." Style="{StaticResource SecondaryText}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
