<UserControl x:Class="GabrielOS.Presentation.Views.WeeklyReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GabrielOS.Presentation.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}"/>
    </UserControl.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- Main Form -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,16,0">
            <StackPanel>
                <TextBlock Style="{StaticResource H1}" Margin="0,0,0,4">
                    <Run Text="Weekly Review"/>
                </TextBlock>
                <TextBlock Text="{Binding WeekLabel}" Style="{StaticResource SecondaryText}" Margin="0,0,0,16"/>

                <!-- Save confirmation -->
                <Border Style="{StaticResource Card}"
                        Visibility="{Binding IsSaved, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="✓ Review saved" Style="{StaticResource BodyText}"
                               Foreground="{DynamicResource AccentCoolBrush}"/>
                </Border>

                <!-- Pillar Scores -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Pillar Scores" Style="{StaticResource H3}" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding PillarScores}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,12">
                                        <Grid>
                                            <TextBlock Text="{Binding PillarName}" Style="{StaticResource BodyText}"/>
                                            <TextBlock Text="{Binding Score}" Style="{StaticResource BodyText}"
                                                       HorizontalAlignment="Right" Foreground="{DynamicResource AccentPrimaryBrush}"/>
                                        </Grid>
                                        <Slider Value="{Binding Score}" Minimum="1" Maximum="10"
                                                TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Review Fields -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Wins this week" Style="{StaticResource H3}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Wins, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,16"/>

                        <TextBlock Text="Frictions / what didn't work" Style="{StaticResource H3}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Frictions, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,16"/>

                        <TextBlock Text="What I avoided (and shouldn't have)" Style="{StaticResource H3}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding AvoidedThings, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48" Margin="0,0,0,16"/>

                        <TextBlock Text="Energy drains" Style="{StaticResource H3}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding EnergyDrains, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48" Margin="0,0,0,16"/>

                        <TextBlock Text="Energy gains" Style="{StaticResource H3}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding EnergyGains, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48" Margin="0,0,0,16"/>

                        <TextBlock Text="Main insight" Style="{StaticResource H3}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding MainInsight, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48" Margin="0,0,0,16"/>

                        <TextBlock Text="Next week focus" Style="{StaticResource H3}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding NextWeekFocus, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48" Margin="0,0,0,16"/>

                        <TextBlock Text="Notes" Style="{StaticResource H3}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48" Margin="0,0,0,16"/>

                        <Button Content="Save Review" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- AI Summary -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="AI Summary" Style="{StaticResource H3}"/>
                            <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right"
                                    Command="{Binding GenerateAISummaryCommand}"
                                    IsEnabled="{Binding AIAvailable}">
                                <Button.Content>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Generate"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGeneratingAI}" Value="True">
                                                        <Setter Property="Text" Value="Generating..."/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button.Content>
                            </Button>
                        </Grid>
                        <TextBox Text="{Binding AiSummary, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Past Reviews sidebar -->
        <DockPanel Grid.Column="1">
            <TextBlock DockPanel.Dock="Top" Text="Past Reviews" Style="{StaticResource H3}" Margin="0,0,0,12"/>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding PastReviews}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Padding="12" Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.LoadWeekCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding WeekStart}"/>
                                </Border.InputBindings>
                                <StackPanel>
                                    <TextBlock Text="{Binding WeekStart, StringFormat='{}{0:dd MMM yyyy}'}"
                                               Style="{StaticResource BodyText}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding MainInsight}" Style="{StaticResource SecondaryText}"
                                               TextWrapping="Wrap" MaxHeight="40" TextTrimming="CharacterEllipsis"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
