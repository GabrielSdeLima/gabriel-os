<UserControl x:Class="GabrielOS.Presentation.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GabrielOS.Presentation.Converters"
             xmlns:enums="clr-namespace:GabrielOS.Domain.Enums;assembly=GabrielOS.Domain">

    <UserControl.Resources>
        <conv:NullableScoreConverter x:Key="NullableScoreConverter"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:InverseToVisibilityConverter x:Key="InverseToVisibilityConverter"/>
        <conv:EnergyColorConverter x:Key="EnergyColorConverter"/>
        <conv:TensionColorConverter x:Key="TensionColorConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- Top row: two columns -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- Left column -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="Dashboard" Style="{StaticResource H1}" Margin="0,0,0,20"/>

                    <!-- Check-in prompt when not done today -->
                    <Border Style="{StaticResource Card}"
                            BorderBrush="{DynamicResource AccentPrimaryBrush}" BorderThickness="1"
                            Visibility="{Binding HasCheckInToday, Converter={StaticResource InverseToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Você ainda não fez check-in hoje." Style="{StaticResource BodyText}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Registre seu estado para começar o dia com clareza."
                                       Style="{StaticResource SecondaryText}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Today's Mode (only when done) -->
                    <Border Style="{StaticResource Card}"
                            Visibility="{Binding HasCheckInToday, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Modo de hoje" Style="{StaticResource H3}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding SuggestedModeText}" Style="{StaticResource BodyText}"
                                       TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                        Visibility="{Binding TodayCheckIn, Converter={StaticResource NullToVisibilityConverter}}">
                                <TextBlock Style="{StaticResource SecondaryText}" Margin="0,0,12,0">
                                    <Run Text="E "/>
                                    <Run Text="{Binding TodayCheckIn.Energy}" Foreground="{DynamicResource AccentPrimaryBrush}" FontWeight="SemiBold"/>
                                </TextBlock>
                                <TextBlock Style="{StaticResource SecondaryText}" Margin="0,0,12,0">
                                    <Run Text="M "/>
                                    <Run Text="{Binding TodayCheckIn.Mood}" Foreground="{DynamicResource AccentPrimaryBrush}" FontWeight="SemiBold"/>
                                </TextBlock>
                                <TextBlock Style="{StaticResource SecondaryText}" Margin="0,0,12,0">
                                    <Run Text="C "/>
                                    <Run Text="{Binding TodayCheckIn.Clarity}" Foreground="{DynamicResource AccentPrimaryBrush}" FontWeight="SemiBold"/>
                                </TextBlock>
                                <TextBlock Style="{StaticResource SecondaryText}">
                                    <Run Text="T "/>
                                    <Run Text="{Binding TodayCheckIn.Tension}" FontWeight="SemiBold"
                                         Foreground="{Binding TodayCheckIn.Tension, Converter={StaticResource TensionColorConverter}}"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Top P1 Goals -->
                    <Border Style="{StaticResource Card}"
                            Visibility="{Binding TopGoals.Count, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Metas P1" Style="{StaticResource H3}" Margin="0,0,0,10"/>
                            <ItemsControl ItemsSource="{Binding TopGoals}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Text="{Binding Title}" Style="{StaticResource BodyText}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Style="{StaticResource SecondaryText}" Margin="0,2,0,0"
                                                       Visibility="{Binding NextAction, Converter={StaticResource NullToVisibilityConverter}}">
                                                <Run Text="→ "/>
                                                <Run Text="{Binding NextAction}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Pillar Scores -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Pilares" Style="{StaticResource H3}"/>
                                <TextBlock Style="{StaticResource SecondaryText}" VerticalAlignment="Center" Margin="8,0,0,0">
                                    <Run Text="— Journal esta semana: "/>
                                    <Run Text="{Binding WeeklyJournalCount}" Foreground="{DynamicResource AccentPrimaryBrush}" FontWeight="SemiBold"/>
                                </TextBlock>
                            </StackPanel>
                            <!-- Column headers -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="72"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="Nota" Style="{StaticResource SecondaryText}"
                                           HorizontalAlignment="Center" FontSize="11"/>
                                <TextBlock Grid.Column="2" Text="Tendência" Style="{StaticResource SecondaryText}"
                                           HorizontalAlignment="Center" FontSize="11"/>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding Pillars}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="48"/>
                                                <ColumnDefinition Width="72"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                       Style="{StaticResource BodyText}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Score, Converter={StaticResource NullableScoreConverter}}"
                                                       Style="{StaticResource BodyText}"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Trend, Converter={StaticResource TrendConverter}}"
                                                       Style="{StaticResource SecondaryText}"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                                       FontSize="16"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right column: Alerts -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Alertas" Style="{StaticResource H3}" Margin="0,0,0,12"/>

                    <TextBlock Text="Tudo certo. Nenhum alerta.">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryText}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Alerts.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ItemsControl ItemsSource="{Binding Alerts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" Style="{StaticResource BodyText}"
                                                   FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Message}" Style="{StaticResource SecondaryText}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- CYCLE COMMAND CENTER                               -->
            <!-- ═══════════════════════════════════════════════════ -->

            <!-- No active cycle -->
            <Border Style="{StaticResource Card}"
                    Visibility="{Binding ActiveCycleFocus, Converter={StaticResource InverseToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" Margin="0,16">
                    <TextBlock Text="Nenhum ciclo ativo" Style="{StaticResource H3}"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="Crie um ciclo para vincular metas, tarefas e pilares em uma visão unificada."
                               Style="{StaticResource SecondaryText}" TextWrapping="Wrap"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Active cycle command center -->
            <Border Style="{StaticResource Card}"
                    Visibility="{Binding ActiveCycleFocus, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Central de Comando" Style="{StaticResource H3}"
                               Foreground="{DynamicResource AccentCoolBrush}" Margin="0,0,0,14"/>

                    <!-- Cycle title + days remaining -->
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="{Binding ActiveCycleFocus.Title}" Style="{StaticResource BodyText}"
                                   FontWeight="SemiBold" FontSize="15"/>
                        <TextBlock HorizontalAlignment="Right" Style="{StaticResource SecondaryText}">
                            <Run Text="{Binding CycleDaysRemaining, Mode=OneWay}"/>
                            <Run Text=" dias restantes de "/>
                            <Run Text="{Binding CycleDaysTotal, Mode=OneWay}"/>
                        </TextBlock>
                    </Grid>

                    <!-- Dates -->
                    <TextBlock Style="{StaticResource SecondaryText}" Margin="0,0,0,8">
                        <Run Text="{Binding ActiveCycleFocus.StartDate, StringFormat='{}{0:dd MMM}'}"/>
                        <Run Text=" → "/>
                        <Run Text="{Binding ActiveCycleFocus.EndDate, StringFormat='{}{0:dd MMM yyyy}'}"/>
                    </TextBlock>

                    <!-- Progress bar -->
                    <ProgressBar Value="{Binding CycleProgressPercent}" Maximum="100" Height="6" Margin="0,0,0,4">
                        <ProgressBar.Template>
                            <ControlTemplate TargetType="ProgressBar">
                                <Grid>
                                    <Border CornerRadius="3" Background="#20FFFFFF"/>
                                    <Border x:Name="PART_Track"/>
                                    <Grid x:Name="PART_Indicator" HorizontalAlignment="Left">
                                        <Border CornerRadius="3" Background="{DynamicResource AccentCoolBrush}"/>
                                    </Grid>
                                </Grid>
                            </ControlTemplate>
                        </ProgressBar.Template>
                    </ProgressBar>

                    <!-- Thesis -->
                    <TextBlock Text="{Binding ActiveCycleFocus.Thesis}" Style="{StaticResource SecondaryText}"
                               TextWrapping="Wrap" Margin="0,8,0,0"
                               Visibility="{Binding ActiveCycleFocus.Thesis, Converter={StaticResource NullToVisibilityConverter}}"/>

                    <!-- ── Recent 14 days ── -->
                    <Rectangle Fill="{DynamicResource BorderDefaultBrush}" Height="1" Margin="0,16,0,12"/>
                    <TextBlock Text="Últimos 14 dias" Style="{StaticResource SecondaryText}" Margin="0,0,0,8" FontSize="11"/>
                    <ItemsControl ItemsSource="{Binding RecentDays}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="14"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2" Height="28">
                                    <Border CornerRadius="4" Background="{DynamicResource BackgroundPrimaryBrush}" Opacity="0.7"/>
                                    <Border CornerRadius="4"
                                            Background="{Binding Energy, Converter={StaticResource EnergyColorConverter}}"/>
                                    <!-- Today ring -->
                                    <Border CornerRadius="4" BorderThickness="2"
                                            BorderBrush="{DynamicResource AccentPrimaryBrush}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock Text="{Binding Date.Day}" Style="{StaticResource SecondaryText}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ── Cycle Goals ── -->
                    <Rectangle Fill="{DynamicResource BorderDefaultBrush}" Height="1" Margin="0,12,0,12"
                               Visibility="{Binding HasCycleGoals, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBlock Text="Metas do Ciclo" Style="{StaticResource SecondaryText}" Margin="0,0,0,8" FontSize="11"
                               Visibility="{Binding HasCycleGoals, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <ItemsControl ItemsSource="{Binding CycleGoals}"
                                  Visibility="{Binding HasCycleGoals, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Pillar tag -->
                                    <Border Grid.Column="0" Background="{DynamicResource BackgroundPrimaryBrush}"
                                            CornerRadius="4" Padding="8,3" Margin="0,0,10,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Pillar.Name}" FontSize="11"
                                                   Foreground="{DynamicResource AccentPrimaryBrush}"/>
                                    </Border>
                                    <!-- Goal title -->
                                    <TextBlock Grid.Column="1" Text="{Binding Title}" Style="{StaticResource BodyText}"
                                               VerticalAlignment="Center"/>
                                    <!-- Next action -->
                                    <TextBlock Grid.Column="2" Style="{StaticResource SecondaryText}" FontSize="11"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Visibility="{Binding NextAction, Converter={StaticResource NullToVisibilityConverter}}">
                                        <Run Text="→ "/><Run Text="{Binding NextAction}"/>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ── Active Tasks ── -->
                    <Rectangle Fill="{DynamicResource BorderDefaultBrush}" Height="1" Margin="0,8,0,12"
                               Visibility="{Binding CycleTasks.Count, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBlock Text="Tarefas Ativas" Style="{StaticResource SecondaryText}" Margin="0,0,0,8" FontSize="11"
                               Visibility="{Binding CycleTasks.Count, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <ItemsControl ItemsSource="{Binding CycleTasks}"
                                  Visibility="{Binding CycleTasks.Count, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Status badge -->
                                    <Border Grid.Column="0" CornerRadius="3" Padding="6,2"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#20FFFFFF"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:TaskItemStatus.Doing}">
                                                        <Setter Property="Background" Value="#30A3BE8C"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:TaskItemStatus.Next}">
                                                        <Setter Property="Background" Value="#307C9EBD"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                    <Setter Property="Text" Value=""/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:TaskItemStatus.Doing}">
                                                            <Setter Property="Text" Value="DOING"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentCoolBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:TaskItemStatus.Next}">
                                                            <Setter Property="Text" Value="NEXT"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentPrimaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <!-- Task title -->
                                    <TextBlock Grid.Column="1" Text="{Binding Title}" Style="{StaticResource BodyText}"
                                               VerticalAlignment="Center"/>
                                    <!-- Goal link -->
                                    <TextBlock Grid.Column="2" Style="{StaticResource SecondaryText}" FontSize="11"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Visibility="{Binding Goal, Converter={StaticResource NullToVisibilityConverter}}">
                                        <Run Text="→ "/><Run Text="{Binding Goal.Title}"/>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ── Affected Pillars ── -->
                    <Rectangle Fill="{DynamicResource BorderDefaultBrush}" Height="1" Margin="0,8,0,12"
                               Visibility="{Binding AffectedPillars.Count, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBlock Text="Pilares Impactados" Style="{StaticResource SecondaryText}" Margin="0,0,0,8" FontSize="11"
                               Visibility="{Binding AffectedPillars.Count, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <ItemsControl ItemsSource="{Binding AffectedPillars}"
                                  Visibility="{Binding AffectedPillars.Count, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="48"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource BodyText}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Score, Converter={StaticResource NullableScoreConverter}}"
                                               Style="{StaticResource BodyText}"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Trend, Converter={StaticResource TrendConverter}}"
                                               Style="{StaticResource SecondaryText}"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"
                                               FontSize="16"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
