<UserControl x:Class="GabrielOS.Presentation.Views.GoalListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GabrielOS.Presentation.Converters">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveGoalCommand}"/>
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Goals" Style="{StaticResource H1}" Margin="0,0,0,16"/>

        <!-- Form -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="{Binding FormTitle}" Style="{StaticResource H3}" Margin="0,0,0,8"/>

                <!-- Error -->
                <Border Background="#3D1A1A" CornerRadius="4" Padding="8,6" Margin="0,0,0,8"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource BodyText}"
                               Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap"/>
                </Border>

                <TextBox Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkTextBox}"
                         Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" ItemsSource="{Binding Pillars}" SelectedItem="{Binding NewPillar}"
                              DisplayMemberPath="Name" Style="{StaticResource DarkComboBox}" Margin="0,0,6,0"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding StatusValues}" SelectedItem="{Binding NewStatus}"
                              Style="{StaticResource DarkComboBox}" Margin="0,0,6,0"/>
                    <ComboBox Grid.Column="2" ItemsSource="{Binding PriorityValues}" SelectedItem="{Binding NewPriority}"
                              Style="{StaticResource DarkComboBox}" Margin="0,0,6,0"/>
                    <ComboBox Grid.Column="3" ItemsSource="{Binding HorizonTypes}" SelectedItem="{Binding NewHorizonType}"
                              Style="{StaticResource DarkComboBox}"/>
                </Grid>

                <TextBox Text="{Binding NewNextAction, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkTextBox}"
                         Margin="0,0,0,8"/>

                <TextBox Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkTextBox}"
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48"
                         Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="{Binding SaveButtonText}" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveGoalCommand}" Margin="0,0,8,0"/>
                    <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                            Command="{Binding CancelEditCommand}"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Search + List -->
        <DockPanel Grid.Row="2" Margin="0,4,0,0">
            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkTextBox}" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="Search" Style="{StaticResource PrimaryButton}"
                        Command="{Binding SearchCommand}"/>
            </Grid>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <ItemsControl ItemsSource="{Binding Goals}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Priority}" Style="{StaticResource SecondaryText}"
                                                       Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Text=" · " Style="{StaticResource SecondaryText}"/>
                                            <TextBlock Text="{Binding Status}" Style="{StaticResource SecondaryText}"/>
                                            <TextBlock Text=" · " Style="{StaticResource SecondaryText}"/>
                                            <TextBlock Text="{Binding HorizonType}" Style="{StaticResource SecondaryText}"/>
                                            <TextBlock Text=" · " Style="{StaticResource SecondaryText}"/>
                                            <TextBlock Text="{Binding Pillar.Name}" Style="{StaticResource SecondaryText}"
                                                       Foreground="{StaticResource AccentBrush}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="Edit" Style="{StaticResource SecondaryButton}"
                                                    Command="{Binding DataContext.BeginEditGoalCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" Margin="0,0,6,0"/>
                                            <Button Content="Delete" Style="{StaticResource DangerButton}"
                                                    Command="{Binding DataContext.DeleteGoalCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="{Binding Title}" Style="{StaticResource BodyText}"
                                               FontWeight="SemiBold" Margin="0,4,0,2"/>

                                    <TextBlock Text="{Binding NextAction}" Style="{StaticResource SecondaryText}"
                                               Margin="0,2,0,0" TextWrapping="Wrap"
                                               Visibility="{Binding NextAction, Converter={StaticResource NullToVisibilityConverter}}"/>

                                    <TextBlock Text="{Binding Description}" Style="{StaticResource SecondaryText}"
                                               TextWrapping="Wrap" MaxHeight="60" TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,0"
                                               Visibility="{Binding Description, Converter={StaticResource NullToVisibilityConverter}}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                    <StackPanel Style="{StaticResource EmptyState}"
                                Visibility="{Binding Goals.Count, Converter={StaticResource InverseToVisibilityConverter}}">
                        <TextBlock Text="◈" FontSize="32" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="No goals yet" Style="{StaticResource H3}"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="Add a goal above to get started." Style="{StaticResource SecondaryText}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
