<UserControl x:Class="GabrielOS.Presentation.Views.MonthlyReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GabrielOS.Presentation.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}"/>
    </UserControl.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="260"/>
        </Grid.ColumnDefinitions>

        <!-- Main Form -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,16,0">
            <StackPanel>
                <TextBlock Text="Monthly Review" Style="{StaticResource H1}" Margin="0,0,0,8"/>

                <!-- Month/Year selector -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <ComboBox ItemsSource="{Binding MonthNumbers}" SelectedItem="{Binding Month}"
                              Style="{StaticResource DarkComboBox}" Width="80" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding YearNumbers}" SelectedItem="{Binding Year}"
                              Style="{StaticResource DarkComboBox}" Width="80" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding MonthLabel}" Style="{StaticResource H3}"
                               VerticalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                </StackPanel>

                <!-- Saved confirmation -->
                <Border Style="{StaticResource Card}"
                        Visibility="{Binding IsSaved, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="✓ Review saved" Style="{StaticResource BodyText}"
                               Foreground="{StaticResource AccentBrush}"/>
                </Border>

                <!-- Pillar Scores -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Pillar Scores" Style="{StaticResource H3}" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding PillarScores}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,10">
                                        <Grid>
                                            <TextBlock Text="{Binding PillarName}" Style="{StaticResource BodyText}"/>
                                            <TextBlock Text="{Binding Score}" Style="{StaticResource BodyText}"
                                                       HorizontalAlignment="Right"
                                                       Foreground="{StaticResource PrimaryBrush}"/>
                                        </Grid>
                                        <Slider Value="{Binding Score}" Minimum="1" Maximum="10"
                                                TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Review fields -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Highlights" Style="{StaticResource H3}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Highlights, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,16"/>

                        <TextBlock Text="Lowlights" Style="{StaticResource H3}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Lowlights, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,16"/>

                        <TextBlock Text="Key Learnings" Style="{StaticResource H3}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding KeyLearnings, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,16"/>

                        <TextBlock Text="Next Month Intentions" Style="{StaticResource H3}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding NextMonthIntentions, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,16"/>

                        <Button Content="Save Review" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- AI Summary -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="AI Summary" Style="{StaticResource H3}"/>
                            <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right"
                                    Command="{Binding GenerateAISummaryCommand}">
                                <Button.Content>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Generate AI Summary"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGeneratingAI}" Value="True">
                                                        <Setter Property="Text" Value="Generating..."/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button.Content>
                            </Button>
                        </Grid>
                        <TextBlock Text="Configure Anthropic API key in Settings to enable AI features."
                                   TextWrapping="Wrap" Margin="0,0,0,8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryText}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AIAvailable}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Text="{Binding AiSummary, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Past Reviews sidebar -->
        <DockPanel Grid.Column="1">
            <TextBlock DockPanel.Dock="Top" Text="Past Reviews" Style="{StaticResource H3}" Margin="0,0,0,12"/>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding PastReviews}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="{Binding MonthName}" Style="{StaticResource BodyText}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding KeyLearnings}" Style="{StaticResource SecondaryText}"
                                               TextWrapping="Wrap" MaxHeight="40" TextTrimming="CharacterEllipsis"
                                               Margin="0,4,0,0"
                                               Visibility="{Binding KeyLearnings, Converter={StaticResource NullToVisibilityConverter}}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
