<UserControl x:Class="GabrielOS.Presentation.Views.PillarListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GabrielOS.Presentation.Converters">

    <UserControl.Resources>
        <conv:NullableIntToDoubleConverter x:Key="NullableIntToDoubleConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SavePillarCommand}"/>
    </UserControl.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Pillar List -->
        <DockPanel Grid.Column="0">
            <TextBlock DockPanel.Dock="Top" Text="Pillars" Style="{StaticResource H1}" Margin="0,0,0,16"/>

            <!-- Add New Pillar -->
            <Border DockPanel.Dock="Bottom" Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding NewPillarName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}"
                             Margin="0,0,6,0"/>
                    <Button Grid.Column="1" Content="Add"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddPillarCommand}"
                            Padding="12,6"/>
                </Grid>
            </Border>

            <ListBox ItemsSource="{Binding Pillars}"
                     SelectedItem="{Binding SelectedPillar}"
                     Background="Transparent"
                     BorderThickness="0"
                     ItemContainerStyle="{StaticResource DarkListBoxItem}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Name}" Style="{StaticResource BodyText}" FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Score, TargetNullValue='—'}" Style="{StaticResource SecondaryText}"/>
                                    <TextBlock Text="/10 · " Style="{StaticResource SecondaryText}"
                                               Visibility="{Binding Score, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <TextBlock Text="{Binding Priority}" Style="{StaticResource SecondaryText}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Actions -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="↑" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding DataContext.MovePillarUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Padding="5,2" Margin="0,0,2,0"/>
                                <Button Content="↓" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding DataContext.MovePillarDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Padding="5,2" Margin="0,0,4,0"/>
                                <Button Content="×" Style="{StaticResource DangerButton}"
                                        Command="{Binding DataContext.DeletePillarCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Padding="6,2"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Pillar Detail -->
        <ScrollViewer Grid.Column="1" Margin="24,0,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{Binding SelectedPillar.Name, FallbackValue='Select a pillar'}"
                           Style="{StaticResource H1}" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding SelectedPillar.Description}"
                           Style="{StaticResource SecondaryText}" Margin="0,0,0,20"
                           TextWrapping="Wrap"/>

                <!-- Detail only visible when a pillar is selected -->
                <StackPanel Visibility="{Binding SelectedPillar, Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock Text="Vision" Style="{StaticResource H3}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding SelectedPillar.Vision, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}"
                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                             Margin="0,0,0,16"/>

                    <TextBlock Text="Current State" Style="{StaticResource H3}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding SelectedPillar.CurrentState, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}"
                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                             Margin="0,0,0,16"/>

                    <TextBlock Text="Score (1-10)" Style="{StaticResource H3}" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                                Value="{Binding SelectedPillar.Score, Converter={StaticResource NullableIntToDoubleConverter}}"
                                Minimum="1" Maximum="10"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SelectedPillar.Score, TargetNullValue='—'}"
                                   Style="{StaticResource BodyText}"
                                   Foreground="{DynamicResource AccentPrimaryBrush}"
                                   Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </Grid>

                    <TextBlock Text="Priority" Style="{StaticResource H3}" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding PillarPriorities}"
                              SelectedItem="{Binding SelectedPillar.Priority}"
                              Style="{StaticResource DarkComboBox}"
                              Width="180" HorizontalAlignment="Left"
                              Margin="0,0,0,20"/>

                    <Button Content="Save Changes"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SavePillarCommand}"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
