<UserControl x:Class="GabrielOS.Presentation.Views.MetricListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GabrielOS.Presentation.Converters">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveMetricCommand}"/>
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Metrics" Style="{StaticResource H1}" Margin="0,0,0,16"/>

        <!-- Form -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Log Metric" Style="{StaticResource H3}" Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Metric Name" Style="{StaticResource SecondaryText}"/>
                    <TextBlock Grid.Column="1" Text="Value" Style="{StaticResource SecondaryText}" Margin="6,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="Unit" Style="{StaticResource SecondaryText}" Margin="6,0,0,0"/>
                    <TextBlock Grid.Column="3" Text="Pillar" Style="{StaticResource SecondaryText}" Margin="6,0,0,0"/>
                    <TextBlock Grid.Column="4" Text="Date" Style="{StaticResource SecondaryText}" Margin="6,0,0,0"/>
                </Grid>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}" Margin="0,0,6,0"/>
                    <TextBox Grid.Column="1" Text="{Binding NewValueText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}" Margin="0,0,6,0"/>
                    <TextBox Grid.Column="2" Text="{Binding NewUnit, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}" Margin="0,0,6,0"/>
                    <ComboBox Grid.Column="3" ItemsSource="{Binding Pillars}" SelectedItem="{Binding NewPillar}"
                              DisplayMemberPath="Name" Style="{StaticResource DarkComboBox}" Margin="0,0,6,0"/>
                    <DatePicker Grid.Column="4" SelectedDate="{Binding NewDate}"
                                Style="{StaticResource DarkDatePicker}"/>
                </Grid>

                <TextBlock Text="Notes" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"/>
                <TextBox Text="{Binding NewNotes, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkTextBox}" Margin="0,0,0,8"/>

                <Button Content="Log Metric" Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveMetricCommand}" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <!-- List -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0">
            <Grid>
                <ItemsControl ItemsSource="{Binding Metrics}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}">
                            <Grid>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Date, StringFormat='{}{0:dd MMM yyyy}'}"
                                                   Style="{StaticResource SecondaryText}"/>
                                        <TextBlock Text=" · " Style="{StaticResource SecondaryText}"/>
                                        <TextBlock Text="{Binding Pillar.Name}" Style="{StaticResource SecondaryText}"
                                                   Foreground="{DynamicResource AccentCoolBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource BodyText}"
                                                   FontWeight="SemiBold" Margin="0,0,8,0"/>
                                        <TextBlock Style="{StaticResource BodyText}"
                                                   Foreground="{DynamicResource AccentPrimaryBrush}">
                                            <Run Text="{Binding Value}"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding Unit}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Notes}" Style="{StaticResource SecondaryText}"
                                               TextWrapping="Wrap" Margin="0,2,0,0"
                                               Visibility="{Binding Notes, Converter={StaticResource NullToVisibilityConverter}}"/>
                                </StackPanel>
                                <Button Content="Delete" Style="{StaticResource DangerButton}"
                                        Command="{Binding DataContext.DeleteMetricCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                </ItemsControl>
                <StackPanel Style="{StaticResource EmptyState}"
                            Visibility="{Binding Metrics.Count, Converter={StaticResource InverseToVisibilityConverter}}">
                    <TextBlock Text="∿" FontSize="32" Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="No metrics logged" Style="{StaticResource H3}"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Log your first metric above to start tracking." Style="{StaticResource SecondaryText}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
