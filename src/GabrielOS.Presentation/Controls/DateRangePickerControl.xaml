<UserControl x:Class="GabrielOS.Presentation.Controls.DateRangePickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Border x:Name="MainBorder"
                Background="{DynamicResource BackgroundSecondaryBrush}"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="1" CornerRadius="4"
                Cursor="Hand"
                MouseLeftButtonDown="MainBorder_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="DisplayText"
                           Grid.Column="0"
                           Padding="8,7"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontFamily="{StaticResource MainFont}"
                           FontSize="14"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"/>
                <TextBlock Grid.Column="1"
                           Text="▾"
                           Padding="6,7"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="10"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"/>
            </Grid>
        </Border>
        <Popup x:Name="CalendarPopup"
               Placement="Bottom"
               PlacementTarget="{Binding ElementName=MainBorder}"
               AllowsTransparency="True"
               StaysOpen="False">
            <Calendar x:Name="TheCalendar"
                      SelectionMode="SingleRange"
                      SelectedDatesChanged="TheCalendar_SelectedDatesChanged"/>
        </Popup>
    </Grid>
</UserControl>
