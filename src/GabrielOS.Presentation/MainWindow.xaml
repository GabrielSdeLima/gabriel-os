<Window x:Class="GabrielOS.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:GabrielOS.Presentation.ViewModels"
        xmlns:views="clr-namespace:GabrielOS.Presentation.Views"
        Title="Gabriel OS" Height="900" Width="1340"
        MinHeight="640" MinWidth="1060"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="5"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:PillarListViewModel}"><views:PillarListView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CheckInViewModel}"><views:CheckInView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:JournalListViewModel}"><views:JournalListView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:GoalListViewModel}"><views:GoalListView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:DecisionListViewModel}"><views:DecisionListView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:WeeklyReviewViewModel}"><views:WeeklyReviewView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:MonthlyReviewViewModel}"><views:MonthlyReviewView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CycleFocusViewModel}"><views:CycleFocusView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:TaskListViewModel}"><views:TaskListView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:PatternListViewModel}"><views:PatternListView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:MetricListViewModel}"><views:MetricListView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:PillarTrendViewModel}"><views:PillarTrendView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SearchViewModel}"><views:SearchView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ExportViewModel}"><views:ExportView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><views:SettingsView /></DataTemplate>

        <!-- Window control button style -->
        <Style x:Key="WinCtrlButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#353548"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WinCloseButton" TargetType="Button" BasedOn="{StaticResource WinCtrlButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C0392B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="K" Modifiers="Ctrl" Command="{Binding NavigateToSearchCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding NavigateToDashboardCommand}"/>
        <KeyBinding Key="J" Modifiers="Ctrl" Command="{Binding NavigateToJournalCommand}"/>
        <KeyBinding Key="G" Modifiers="Ctrl" Command="{Binding NavigateToGoalsCommand}"/>
        <KeyBinding Key="OemComma" Modifiers="Ctrl" Command="{Binding NavigateToSettingsCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ TITLE BAR (full width, integrated) ══ -->
        <Grid Grid.Row="0" Background="{StaticResource SidebarBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- App branding (aligns with sidebar width) -->
            <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <Border Width="20" Height="20" CornerRadius="4"
                            Background="{StaticResource PrimaryBrush}" Margin="0,0,8,0">
                        <TextBlock Text="G" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"
                                   Foreground="{StaticResource SidebarBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Gabriel OS" FontFamily="Segoe UI" FontSize="13"
                               FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Section breadcrumb + date -->
            <Border Grid.Column="1" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1" Padding="20,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="2" Height="14" CornerRadius="1"
                                Background="{StaticResource PrimaryBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding CurrentSection}"
                                   FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding TodayFormatted}"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Window controls -->
            <Border Grid.Column="2" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="MinimizeBtn" Content="─" Style="{StaticResource WinCtrlButton}"
                            Click="MinimizeBtn_Click"/>
                    <Button x:Name="MaximizeBtn" Content="□" Style="{StaticResource WinCtrlButton}"
                            Click="MaximizeBtn_Click"/>
                    <Button x:Name="CloseBtn" Content="✕" Style="{StaticResource WinCloseButton}"
                            Click="CloseBtn_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══ MAIN AREA ══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar (no title — moved to title bar) -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Search hint -->
                    <Border DockPanel.Dock="Top" Margin="12,12,12,8"
                            Background="{StaticResource SurfaceBrush}"
                            CornerRadius="4" Padding="8,6" Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding NavigateToSearchCommand}"/>
                        </Border.InputBindings>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⌕  Search..." Style="{StaticResource SecondaryText}" FontSize="13"/>
                            <TextBlock Text="Ctrl+K" Style="{StaticResource SecondaryText}" FontSize="11"
                                       Margin="8,0,0,0" Opacity="0.5"/>
                        </StackPanel>
                    </Border>

                    <!-- Navigation -->
                    <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="CORE" Style="{StaticResource SecondaryText}" FontSize="10"
                                       Margin="16,4,16,4" FontWeight="Bold" Opacity="0.5"/>
                            <Button Content="◉  Dashboard" Style="{StaticResource SidebarButton}" Command="{Binding NavigateToDashboardCommand}"/>
                            <Button Content="◎  Check-in" Style="{StaticResource SidebarButton}" Command="{Binding NavigateToCheckInCommand}"/>
                            <Button Content="◇  Journal" Style="{StaticResource SidebarButton}" Command="{Binding NavigateToJournalCommand}"/>

                            <TextBlock Text="PLANNING" Style="{StaticResource SecondaryText}" FontSize="10"
                                       Margin="16,12,16,4" FontWeight="Bold" Opacity="0.5"/>
                            <Button Content="◫  Pillars" Style="{StaticResource SidebarButton}" Command="{Binding NavigateToPillarsCommand}"/>
                            <Button Content="◈  Goals" Style="{StaticResource SidebarButton}" Command="{Binding NavigateToGoalsCommand}"/>
                            <Button Content="▷  Tasks" Style="{StaticResource SidebarButton}" Command="{Binding NavigateToTasksCommand}"/>
                            <Button Content="◑  Cycle Focus" Style="{StaticResource SidebarButton}" Command="{Binding NavigateToCycleFocusCommand}"/>

                            <TextBlock Text="REFLECTION" Style="{StaticResource SecondaryText}" FontSize="10"
                                       Margin="16,12,16,4" FontWeight="Bold" Opacity="0.5"/>
                            <Button Content="◐  Weekly Review" Style="{StaticResource SidebarButton}" Command="{Binding NavigateToWeeklyReviewCommand}"/>
                            <Button Content="◌  Monthly Review" Style="{StaticResource SidebarButton}" Command="{Binding NavigateToMonthlyReviewCommand}"/>
                            <Button Content="△  Decisions" Style="{StaticResource SidebarButton}" Command="{Binding NavigateToDecisionsCommand}"/>
                            <Button Content="⟳  Patterns" Style="{StaticResource SidebarButton}" Command="{Binding NavigateToPatternsCommand}"/>

                            <TextBlock Text="ANALYTICS" Style="{StaticResource SecondaryText}" FontSize="10"
                                       Margin="16,12,16,4" FontWeight="Bold" Opacity="0.5"/>
                            <Button Content="∿  Metrics" Style="{StaticResource SidebarButton}" Command="{Binding NavigateToMetricsCommand}"/>
                            <Button Content="📈  Pillar Trends" Style="{StaticResource SidebarButton}" Command="{Binding NavigateToPillarTrendsCommand}"/>

                            <TextBlock Text="SYSTEM" Style="{StaticResource SecondaryText}" FontSize="10"
                                       Margin="16,12,16,4" FontWeight="Bold" Opacity="0.5"/>
                            <Button Content="↓  Export" Style="{StaticResource SidebarButton}" Command="{Binding NavigateToExportCommand}"/>
                            <Button Content="⚙  Settings" Style="{StaticResource SidebarButton}" Command="{Binding NavigateToSettingsCommand}"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Content -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}" Margin="24,20,24,20"/>
        </Grid>
    </Grid>
</Window>
