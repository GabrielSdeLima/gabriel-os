<Window x:Class="GabrielOS.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GabrielOS.Presentation.ViewModels"
        xmlns:views="clr-namespace:GabrielOS.Presentation.Views"
        Title="Gabriel OS" Height="800" Width="1200"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PillarListViewModel}">
            <views:PillarListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CheckInViewModel}">
            <views:CheckInView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:JournalListViewModel}">
            <views:JournalListView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- App Title -->
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,24">
                    <TextBlock Text="Gabriel OS" Style="{StaticResource H2}"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="Life Operating System" Style="{StaticResource SecondaryText}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel>
                    <Button Content="◉  Dashboard" Style="{StaticResource SidebarButton}"
                            Command="{Binding NavigateToDashboardCommand}"/>
                    <Button Content="◫  Pillars" Style="{StaticResource SidebarButton}"
                            Command="{Binding NavigateToPillarsCommand}"/>
                    <Button Content="◎  Check-in" Style="{StaticResource SidebarButton}"
                            Command="{Binding NavigateToCheckInCommand}"/>
                    <Button Content="◇  Journal" Style="{StaticResource SidebarButton}"
                            Command="{Binding NavigateToJournalCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}"
                         Margin="24,20,24,20"/>
    </Grid>
</Window>
